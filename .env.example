# SIEM Box Environment Configuration
# Copy this file to .env and update the values for your environment

# Database Configuration
POSTGRES_DB=siembox
POSTGRES_USER=your-db-username
POSTGRES_PASSWORD=your-db-password

# Backend Configuration
DATABASE_URL=postgresql://your-db-username:your-db-password@postgres:5432/siembox
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32

# Security Settings
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Notification Configuration (Optional)
# Email Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
EMAIL_FROM=your-email@gmail.com

# Discord Webhook (Optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Slack Webhook (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your-webhook-url
SLACK_TOKEN=xoxb-your-slack-bot-token

# SMS Configuration (Twilio) - Optional
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Cribl API Configuration
CRIBL_API_URL=http://cribl:9000/api/v1
CRIBL_API_TOKEN=your-cribl-api-token
CRIBL_SEARCH_TIMEOUT=30

# Vulnerability Scanning Configuration
NMAP_ENABLED=true
TRIVY_ENABLED=true

# Log Retention (days)
LOG_RETENTION_DAYS=30
ALERT_RETENTION_DAYS=90

# Performance Settings
MAX_LOG_BATCH_SIZE=1000
LOG_PROCESSING_INTERVAL=5

# Frontend Configuration
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000

# Development Settings
ENABLE_DEBUG_LOGGING=false
ENABLE_PROFILING=false