# SIEMBox Environment Configuration
# Copy this file to .env and update with your values
# NEVER commit the .env file to version control!

# Node Environment
NODE_ENV=production

# Backend API Configuration
PORT=8421
HOST=0.0.0.0
LOG_LEVEL=info

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=siembox
DB_USER=siembox
DB_PASSWORD=changeme

# Security
JWT_SECRET=change-this-to-a-random-secret-key
DEFAULT_ADMIN_PASSWORD=changeme

# Credential Encryption (scanner credentials + the AI builder API key, encrypted at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=changeme_generate_a_new_64_character_hex_key

# AI builder (optional) — provider keys. You can instead set the key in the UI
# (Settings -> AI Builder), which stores it encrypted using the key above.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Parser/detection catalog (optional overrides; defaults to cladkins/siembox-parsers).
# SIEMBOX_CATALOG_REPO=cladkins/siembox-catalog
# SIEMBOX_CATALOG_REF=main
# GITHUB_TOKEN=

# SIEMBox is catalog-only by default: a fresh install ships with no bundled
# parsers or detection rules, and you install exactly what you want from the
# in-app catalog (Parsers / Detection Rules -> Browse Catalog -> Install all).
# Set this to true to opt back into auto-importing the bundled detection rules
# on startup (legacy behaviour). Defaults to catalog-only when unset.
# SEED_BUNDLED_CONTENT=true

# CORS Configuration
CORS_ORIGIN=*

# Frontend Configuration
VITE_API_URL=/api

# GeoIP Enrichment (DB-IP IP-to-Country Lite, CC BY 4.0)
# Path the backend reads the MMDB from (inside the container).
GEOIP_DB_PATH=/app/data/dbip-country-lite.mmdb
# Comma-separated ISO-2 home countries (e.g. US,CA). Logins from anywhere else
# get geo_foreign=true. Leave empty to disable foreign-country detection.
GEOIP_HOME_COUNTRIES=

# Container Scanning — optional Docker host image discovery.
# To list the images already running on the host (Container Scanning -> "Images
# on this Docker host"), mount the Docker socket into the backend container in
# compose.prod.yaml. WARNING: that grants the container Docker access (root-
# equivalent on the host); it is opt-in and off by default. Override the socket
# path here only if it isn't at the default location below.
# DOCKER_SOCKET_PATH=/var/run/docker.sock

# Threat Intelligence Feeds (Threat Intel page)
# Free, no-auth IP blocklists (abuse.ch Feodo/SSLBL, Tor exit nodes, blocklist.de)
# are seeded and refreshed automatically — they only need the backend to have
# OUTBOUND HTTPS egress. If egress is blocked, feeds just show last_status=error.
# Reputation providers (AbuseIPDB, GreyNoise) are bring-your-own-key and are
# configured in the UI (keys encrypted at rest with CREDENTIAL_ENCRYPTION_KEY) —
# there are no env vars for them.
