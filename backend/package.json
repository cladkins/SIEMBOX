{
  "name": "siembox-backend",
  "version": "3.0.0",
  "description": "SIEMBox Backend - Syslog collection, parsing, and detection engine",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "start": "node dist/server.js",
    "migrate": "node dist/scripts/migrate.js",
    "import-rules": "node dist/scripts/import-rules.js",
    "validate-parsers": "node dist/scripts/validate-parsers.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "validate-detections": "node dist/scripts/validate-detections.js"
  },
  "keywords": [
    "siem",
    "syslog",
    "security",
    "monitoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "js-yaml": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "mmdb-lib": "^3.0.2",
    "node-nmap": "^4.0.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
