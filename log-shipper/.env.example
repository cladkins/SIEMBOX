# SIEMBox Log Shipper Configuration
# Copy this file to .env and customize for your environment
# cp .env.example .env

# ==============================================================================
# REQUIRED: SIEMBox Connection Settings
# ==============================================================================
# IP address or hostname of your SIEMBox server
SIEM_HOST=192.168.1.76

# Syslog port (default: 514)
SIEM_PORT=514

# Protocol: udp or tcp (default: udp)
SIEM_PROTOCOL=udp

# Hostname identifier for this shipper (appears in logs)
SHIPPER_HOSTNAME=log-shipper

# Container name (optional)
CONTAINER_NAME=siembox-log-shipper

# Network mode (host or bridge)
NETWORK_MODE=host

# ==============================================================================
# FILE-BASED LOG SOURCES
# ==============================================================================
# Format: FILE_N=/path/to/file;tag;facility
#
# Path: Full path to log file inside container (after volume mount)
# Tag: Identifier for filtering in SIEMBox
# Facility: Syslog facility (local0-local7)
#
# Don't forget to uncomment the corresponding volume mount in docker-compose.yml!
# ==============================================================================

# --- Example 1: NPM (Nginx Proxy Manager) Logs ---
# Uncomment these if forwarding NPM logs
# Volume mount required: /etc/komodo/stacks/npm/data/logs:/logs:ro

# FILE_1=/logs/proxy-host-1.log;npm-access;local0
# FILE_2=/logs/proxy-host-2.log;npm-access;local0
# FILE_3=/logs/proxy-host-3.log;npm-access;local0
# FILE_4=/logs/error.log;npm-error;local0
# FILE_5=/logs/default.log;npm-default;local0

# --- Example 2: Host System Logs ---
# Uncomment these if forwarding host logs
# Volume mount required: /var/log:/host-logs:ro

# FILE_1=/host-logs/auth.log;auth;local2
# FILE_2=/host-logs/syslog;syslog;local2
# FILE_3=/host-logs/kern.log;kernel;local2

# --- Example 3: Custom Application Logs ---
# Customize these for your application
# Volume mount required: /path/to/your/logs:/app-logs:ro

# FILE_1=/app-logs/application.log;myapp;local1
# FILE_2=/app-logs/error.log;myapp-error;local1
# FILE_3=/app-logs/access.log;myapp-access;local0

# --- Add more file sources as needed (up to FILE_10) ---
# FILE_6=
# FILE_7=
# FILE_8=
# FILE_9=
# FILE_10=

# ==============================================================================
# DOCKER CONTAINER LOG SOURCES
# ==============================================================================
# Format: DOCKER_N=container_name;tag;facility
#
# Container: Name of Docker container to monitor
# Tag: Identifier for filtering in SIEMBox
# Facility: Syslog facility (local0-local7)
#
# Volume mount required: /var/run/docker.sock:/var/run/docker.sock:ro
# ==============================================================================

# --- Example: Forward logs from specific containers ---
# DOCKER_1=nginx;nginx;local3
# DOCKER_2=postgres;database;local3
# DOCKER_3=redis;cache;local3
# DOCKER_4=webapp;application;local1
# DOCKER_5=

# ==============================================================================
# SYSTEMD JOURNAL SOURCES
# ==============================================================================
# Format: JOURNAL_N=unit_name;tag;facility
#
# Unit: Systemd unit name (e.g., sshd, docker, nginx)
# Tag: Identifier for filtering in SIEMBox
# Facility: Syslog facility (local0-local7)
#
# Requires: Host PID namespace and systemd journal access
# ==============================================================================

# --- Example: System services ---
# JOURNAL_1=sshd;ssh;local4
# JOURNAL_2=docker;docker-daemon;local4
# JOURNAL_3=nginx;nginx-service;local4

# ==============================================================================
# COMMON CONFIGURATION EXAMPLES
# ==============================================================================

# ------------------------
# NPM Only (Your Use Case)
# ------------------------
# 1. Uncomment NPM FILE_* variables above
# 2. In docker-compose.yml, uncomment:
#    - /etc/komodo/stacks/npm/data/logs:/logs:ro
# 3. Set SHIPPER_HOSTNAME=npm-server

# ------------------------
# Host System Monitoring
# ------------------------
# 1. Uncomment host system FILE_* variables above
# 2. Uncomment JOURNAL_* variables if using systemd
# 3. In docker-compose.yml, uncomment:
#    - /var/log:/host-logs:ro
#    - /var/run/docker.sock:/var/run/docker.sock:ro (for JOURNAL)
# 4. Set SHIPPER_HOSTNAME=your-hostname

# ------------------------
# Docker Container Logs
# ------------------------
# 1. Uncomment DOCKER_* variables above
# 2. In docker-compose.yml, uncomment:
#    - /var/run/docker.sock:/var/run/docker.sock:ro
# 3. Set SHIPPER_HOSTNAME=docker-host

# ------------------------
# Mixed (Files + Docker)
# ------------------------
# 1. Uncomment any FILE_* and DOCKER_* variables you need
# 2. In docker-compose.yml, uncomment corresponding volume mounts
# 3. Set descriptive SHIPPER_HOSTNAME

# ==============================================================================
# SYSLOG FACILITY GUIDE
# ==============================================================================
# local0 - General application logs, web server access logs
# local1 - Application-specific logs
# local2 - System logs (auth, syslog, kernel)
# local3 - Container/service logs
# local4 - Security/authentication logs
# local5 - Reserved for future use
# local6 - Reserved for future use
# local7 - Reserved for future use
