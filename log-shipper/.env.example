# SIEMBox Managed Log Shipper Configuration
# Copy this file to .env and configure with your values
# cp .env.example .env

# ==============================================================================
# REQUIRED: SIEMBox API Authentication
# ==============================================================================
# API key from SIEMBox UI (Shippers page → Add Shipper)
# This key authenticates the shipper and allows it to fetch configuration
SHIPPER_API_KEY=your_api_key_here

# SIEMBox API URL (change to your SIEMBox server IP/hostname)
# Examples:
#   http://192.168.1.100:8421/api
#   http://siembox.example.com:8421/api
SIEMBOX_API_URL=http://localhost:8421/api

# ==============================================================================
# OPTIONAL: Polling and Heartbeat Settings
# ==============================================================================
# Configuration poll interval (seconds)
# How often the shipper checks for configuration updates from SIEMBox
CONFIG_POLL_INTERVAL=30

# Heartbeat interval (seconds)
# How often the shipper sends a heartbeat to update "last seen" status
HEARTBEAT_INTERVAL=60

# ==============================================================================
# LOG SOURCES CONFIGURATION
# ==============================================================================
# Log sources (files, Docker containers, etc.) are configured through the
# SIEMBox UI, not in this .env file.
#
# Steps to configure log sources:
# 1. Login to SIEMBox UI
# 2. Navigate to Shippers page
# 3. Click on your shipper
# 4. Add log sources (files, Docker containers, etc.)
# 5. Configure volume mounts in compose.yml to match your log paths
#
# The shipper automatically fetches and applies configuration from the API.
# Changes made in the UI are applied within CONFIG_POLL_INTERVAL seconds.
#
# ==============================================================================

# ==============================================================================
# VOLUME MOUNT EXAMPLES FOR compose.yml
# ==============================================================================
# Based on your log sources configured in SIEMBox UI, you'll need to mount
# the appropriate directories in compose.yml:
#
# For file-based logs:
#   - /var/log/nginx:/var/log/nginx:ro
#   - /path/to/app/logs:/logs:ro
#
# For Docker container logs:
#   - /var/run/docker.sock:/var/run/docker.sock:ro
#
# For persistent cache (recommended):
#   - shipper-cache:/tmp
#
# Edit compose.yml and uncomment/add the volumes you need.
# ==============================================================================
